{
  "name": "rechnungsvorfilterung-backend",
  "version": "1.0.0",
  "description": "ABBYY Rechnungsvorfilterung Backend for Althoff Hotels & Resorts",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "echo \"No tests configured\" && exit 0",
    "build:exe": "pkg . --targets node18-win-x64 --output ../dist/Rechnungsvorfilterung.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/better-sqlite3/build/**/*",
      "node_modules/sharp/build/**/*",
      "node_modules/tesseract.js-core/**/*",
      "node_modules/tesseract.js/src/worker-script/**/*"
    ],
    "scripts": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "fuse.js": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.33.2",
    "sql.js": "^1.14.1",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
